--1 Total revenue per day--
SELECT
    order_date,
    SUM(total_price) AS total_revenue
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES
GROUP BY order_date
ORDER BY order_date;

--2 Top 5 products by revenue in last 30 day--
SELECT
    fs.product_id,
    dp.product_category_name,
    SUM(fs.total_price) AS revenue
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES fs
JOIN ECOMMERCE.RAW_ANALYTICS.DIM_PRODUCTS dp
    ON fs.product_id = dp.product_id
WHERE fs.order_date >= (
    SELECT DATEADD(DAY, -30, MAX(order_date))
    FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES
)
GROUP BY
    fs.product_id,
    dp.product_category_name
ORDER BY revenue DESC
LIMIT 5;

--3 Monthly active customers--
SELECT
    DATE_TRUNC('month', fs.order_date) AS month,
    COUNT(DISTINCT fs.customer_id) AS active_customers
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES fs
GROUP BY DATE_TRUNC('month', fs.order_date)
ORDER BY month;

--4 Average order value per customer--
SELECT
    fs.customer_id,
    AVG(fs.total_price) AS avg_order_value
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES fs
GROUP BY fs.customer_id
ORDER BY avg_order_value DESC;

--5 Data Anomaly--
-- price <= 0
SELECT *
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES
WHERE TOTAL_PRICE <= 0;

-- quantity <= 0
SELECT *
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES
WHERE quantity <= 0;


-- missing customer
SELECT *
FROM ECOMMERCE.RAW_ANALYTICS.FACT_SALES
WHERE customer_id IS NULL;
